# ================================================================================
# DOCKERIGNORE - Files to exclude from Docker build context
# ================================================================================
# Giống .gitignore nhưng cho Docker
# Files này KHÔNG được copy vào image
# → Faster builds, smaller context, better security
# ================================================================================

# Git
.git
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment files (SECRETS!)
.env
.env.*

# Build artifacts
bin/
dist/
*.exe

# Test files
*_test.go
coverage.out
coverage.html

# Documentation
*.md
docs/

# Development tools
Makefile
.air.toml

# OS files
.DS_Store
Thumbs.db
