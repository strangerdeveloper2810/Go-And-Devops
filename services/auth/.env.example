# auth local env sample.
# Copy to .env (gitignored). All vars use prefix PM_AUTH_.

PM_AUTH_ENV=dev
PM_AUTH_LOG_LEVEL=debug

# Database — REQUIRED (config validate sẽ fail nếu trống)
PM_AUTH_DATABASE_URL=postgres://postgres:postgres@localhost:5432/pmdb?sslmode=disable

PM_AUTH_SERVER_HTTP_PORT=8001
PM_AUTH_SERVER_GRPC_PORT=9001
PM_AUTH_SERVER_READ_TIMEOUT=15s
PM_AUTH_SERVER_WRITE_TIMEOUT=15s
PM_AUTH_SERVER_SHUTDOWN_TIMEOUT=30s

# JWT — shared across services (load from secret manager in prod)
PM_AUTH_JWT_ACCESS_SECRET=dev-access-secret-change-me
PM_AUTH_JWT_REFRESH_SECRET=dev-refresh-secret-change-me

PM_AUTH_JWT_ACCESS_TTL=15m
PM_AUTH_JWT_REFRESH_TTL=168h

# OpenTelemetry. Set enabled=true and start the observability profile to ship traces.
PM_AUTH_OTEL_ENABLED=false
PM_AUTH_OTEL_SERVICE_NAME=auth
PM_AUTH_OTEL_OTLP_ENDPOINT=otel-collector:4317
PM_AUTH_OTEL_TRACE_SAMPLE_RATE=1.0

# Upstream gRPC addresses (filled as services come online)
PM_AUTH_UPSTREAM_AUTH_ADDR=auth-service:9001
PM_AUTH_UPSTREAM_WORKSPACE_ADDR=workspace-service:9002
PM_AUTH_UPSTREAM_ISSUE_ADDR=issue-service:9003
PM_AUTH_UPSTREAM_PAGE_ADDR=page-service:9004
PM_AUTH_UPSTREAM_FILE_ADDR=file-service:9005
PM_AUTH_UPSTREAM_SEARCH_ADDR=search-service:9006
PM_AUTH_UPSTREAM_NOTIFICATION_ADDR=notification-service:9007
PM_AUTH_UPSTREAM_AI_ADDR=ai-service:9008
PM_AUTH_UPSTREAM_REALTIME_ADDR=realtime-service:9010
PM_AUTH_UPSTREAM_REPORT_ADDR=report-service:9011
PM_AUTH_UPSTREAM_AUDIT_ADDR=audit-service:9012
