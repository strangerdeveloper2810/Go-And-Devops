# page local env sample.
# Copy to .env (gitignored). All vars use prefix PM_PAGE_.

PM_PAGE_ENV=dev
PM_PAGE_LOG_LEVEL=debug

# Database — REQUIRED (config validate sẽ fail nếu trống)
PM_PAGE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/pmdb?sslmode=disable

PM_PAGE_SERVER_HTTP_PORT=8004
PM_PAGE_SERVER_GRPC_PORT=9004
PM_PAGE_SERVER_READ_TIMEOUT=15s
PM_PAGE_SERVER_WRITE_TIMEOUT=15s
PM_PAGE_SERVER_SHUTDOWN_TIMEOUT=30s

# Kafka — consume user.created events (auth-service) + workspace.events (workspace-service).
PM_PAGE_KAFKA_BROKERS=localhost:9094
PM_PAGE_KAFKA_USER_EVENTS_TOPIC=auth.user.events
PM_PAGE_KAFKA_WORKSPACE_EVENTS_TOPIC=workspace.events
PM_PAGE_KAFKA_CONSUMER_GROUP=page-service

# OpenTelemetry. Set enabled=true and start the observability profile to ship traces.
PM_PAGE_OTEL_ENABLED=false
PM_PAGE_OTEL_SERVICE_NAME=page
PM_PAGE_OTEL_OTLP_ENDPOINT=otel-collector:4317
PM_PAGE_OTEL_TRACE_SAMPLE_RATE=1.0
