# api-gateway local env sample.
# Copy to .env (gitignored). All vars use prefix PM_API_GATEWAY_.

PM_API_GATEWAY_ENV=dev
PM_API_GATEWAY_LOG_LEVEL=debug

PM_API_GATEWAY_SERVER_HTTP_PORT=8000
PM_API_GATEWAY_SERVER_GRPC_PORT=9000
PM_API_GATEWAY_SERVER_READ_TIMEOUT=15s
PM_API_GATEWAY_SERVER_WRITE_TIMEOUT=15s
PM_API_GATEWAY_SERVER_SHUTDOWN_TIMEOUT=30s

# JWT — shared across services (load from secret manager in prod)
PM_API_GATEWAY_JWT_ACCESS_SECRET=dev-access-secret-change-me
PM_API_GATEWAY_JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# OpenTelemetry. Set enabled=true and start the observability profile to ship traces.
PM_API_GATEWAY_OTEL_ENABLED=false
PM_API_GATEWAY_OTEL_SERVICE_NAME=api-gateway
PM_API_GATEWAY_OTEL_OTLP_ENDPOINT=otel-collector:4317
PM_API_GATEWAY_OTEL_TRACE_SAMPLE_RATE=1.0

# Upstream gRPC addresses (filled as services come online)
PM_API_GATEWAY_UPSTREAM_AUTH_ADDR=auth-service:9001
# Auth HTTP addr — reverse proxy cho /api/v1/auth/* (register/login)
PM_API_GATEWAY_UPSTREAM_AUTH_HTTP_ADDR=auth-service:8001
PM_API_GATEWAY_UPSTREAM_WORKSPACE_ADDR=workspace-service:9002
# Workspace HTTP addr — reverse proxy cho /api/v1/workspaces/*
PM_API_GATEWAY_UPSTREAM_WORKSPACE_HTTP_ADDR=workspace-service:8002
PM_API_GATEWAY_UPSTREAM_ISSUE_ADDR=issue-service:9003
# Issue HTTP addr — reverse proxy cho /api/v1/issues/* và /api/v1/projects/*
PM_API_GATEWAY_UPSTREAM_ISSUE_HTTP_ADDR=issue-service:8003
PM_API_GATEWAY_UPSTREAM_PAGE_ADDR=page-service:9004
# Page HTTP addr — reverse proxy cho /api/v1/spaces/* và /api/v1/pages/*
PM_API_GATEWAY_UPSTREAM_PAGE_HTTP_ADDR=page-service:8004
PM_API_GATEWAY_UPSTREAM_FILE_ADDR=file-service:9005
PM_API_GATEWAY_UPSTREAM_SEARCH_ADDR=search-service:9006
PM_API_GATEWAY_UPSTREAM_NOTIFICATION_ADDR=notification-service:9007
PM_API_GATEWAY_UPSTREAM_AI_ADDR=ai-service:9008
PM_API_GATEWAY_UPSTREAM_REALTIME_ADDR=realtime-service:9010
PM_API_GATEWAY_UPSTREAM_REPORT_ADDR=report-service:9011
PM_API_GATEWAY_UPSTREAM_AUDIT_ADDR=audit-service:9012
