# issue-service — copy to .env (gitignored) for local runs. Do NOT commit real secrets.
PM_ISSUE_SERVER_HTTP_PORT=8003
PM_ISSUE_DATABASE_URL=jdbc:postgresql://localhost:5432/pmdb?currentSchema=issue
PM_ISSUE_DATABASE_USER=postgres
PM_ISSUE_DATABASE_PASSWORD=postgres
PM_ISSUE_KAFKA_BROKERS=localhost:9094
PM_ISSUE_KAFKA_CONSUMER_GROUP=issue-service
