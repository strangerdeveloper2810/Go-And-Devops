# workspace local env sample.
# Copy to .env (gitignored). All vars use prefix PM_WORKSPACE_.

PM_WORKSPACE_ENV=dev
PM_WORKSPACE_LOG_LEVEL=debug

# Database — REQUIRED (config validate sẽ fail nếu trống)
PM_WORKSPACE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/pmdb?sslmode=disable

PM_WORKSPACE_SERVER_HTTP_PORT=8002
PM_WORKSPACE_SERVER_GRPC_PORT=9002
PM_WORKSPACE_SERVER_READ_TIMEOUT=15s
PM_WORKSPACE_SERVER_WRITE_TIMEOUT=15s
PM_WORKSPACE_SERVER_SHUTDOWN_TIMEOUT=30s

# Kafka — consume user.created events produced by auth-service.
PM_WORKSPACE_KAFKA_BROKERS=localhost:9094
PM_WORKSPACE_KAFKA_USER_EVENTS_TOPIC=auth.user.events
PM_WORKSPACE_KAFKA_CONSUMER_GROUP=workspace-service

# OpenTelemetry. Set enabled=true and start the observability profile to ship traces.
PM_WORKSPACE_OTEL_ENABLED=false
PM_WORKSPACE_OTEL_SERVICE_NAME=workspace
PM_WORKSPACE_OTEL_OTLP_ENDPOINT=otel-collector:4317
PM_WORKSPACE_OTEL_TRACE_SAMPLE_RATE=1.0
