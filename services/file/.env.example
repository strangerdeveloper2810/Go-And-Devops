# file local env sample.
# Copy to .env (gitignored). All vars use prefix PM_FILE_.

PM_FILE_ENV=dev
PM_FILE_LOG_LEVEL=debug

# Database — REQUIRED (config validate sẽ fail nếu trống)
PM_FILE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/pmdb?sslmode=disable

PM_FILE_SERVER_HTTP_PORT=8005
PM_FILE_SERVER_GRPC_PORT=9005
PM_FILE_SERVER_READ_TIMEOUT=15s
PM_FILE_SERVER_WRITE_TIMEOUT=15s
PM_FILE_SERVER_SHUTDOWN_TIMEOUT=30s

# MinIO (S3-compatible object storage) — lưu nội dung file/attachment.
# Dev creds khớp infra/dev/.env.example (minioadmin/minioadmin).
PM_FILE_MINIO_ENDPOINT=localhost:9100
PM_FILE_MINIO_ACCESS_KEY=minioadmin
PM_FILE_MINIO_SECRET_KEY=minioadmin
PM_FILE_MINIO_BUCKET=pm-attachments
PM_FILE_MINIO_USE_SSL=false

# OpenTelemetry. Set enabled=true and start the observability profile to ship traces.
PM_FILE_OTEL_ENABLED=false
PM_FILE_OTEL_SERVICE_NAME=file
PM_FILE_OTEL_OTLP_ENDPOINT=otel-collector:4317
PM_FILE_OTEL_TRACE_SAMPLE_RATE=1.0
