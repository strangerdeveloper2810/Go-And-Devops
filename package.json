{
  "name": "pm-platform",
  "private": true,
  "version": "0.0.0",
  "description": "PM Platform — Jira + Confluence + AI/MCP internal team platform",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "biome format --write .",
    "infra:dev:up": "docker compose -f infra/dev/docker-compose.yml up -d",
    "infra:dev:down": "docker compose -f infra/dev/docker-compose.yml down",
    "infra:dev:logs": "docker compose -f infra/dev/docker-compose.yml logs -f",
    "proto:gen": "cd proto && buf generate",
    "proto:lint": "cd proto && buf lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3"
  }
}
