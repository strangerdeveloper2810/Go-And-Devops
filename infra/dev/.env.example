# PM Platform — Dev environment variables sample
# Copy to .env (gitignored) and fill in real values.

# ─── Postgres ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pmdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Per-service DB user passwords (created by 00-init.sh).
# Each service connects with its own user that only has access to its schema.
DB_PASSWORD_AUTH=auth_pwd_dev
DB_PASSWORD_WORKSPACE=workspace_pwd_dev
DB_PASSWORD_ISSUE=issue_pwd_dev
DB_PASSWORD_PAGE=page_pwd_dev
DB_PASSWORD_FILE=file_pwd_dev
DB_PASSWORD_AI=ai_pwd_dev
DB_PASSWORD_NOTIFICATION=notif_pwd_dev
DB_PASSWORD_REPORT=report_pwd_dev
DB_PASSWORD_AUDIT=audit_pwd_dev

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=redis
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Kafka ───────────────────────────────────────────────────
# Cluster ID must be a 22-char base64-url string. Generate with:
#   docker run --rm apache/kafka:3.9.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_BROKERS=kafka:9092
KAFKA_BROKERS_EXTERNAL=localhost:9094
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ─── Elasticsearch ───────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─── MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ATTACHMENTS=pm-attachments
MINIO_BUCKET_AVATARS=pm-avatars
MINIO_BUCKET_PAGE_IMAGES=pm-page-images
MINIO_BUCKET_EXPORTS=pm-exports

# ─── Grafana (observability profile) ─────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── App ─────────────────────────────────────────────────────
ENV=dev
LOG_LEVEL=debug

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL_SECONDS=900       # 15 minutes
JWT_REFRESH_TTL_SECONDS=2592000  # 30 days

# Google OAuth (get from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://app.localhost/oauth/google/callback

# Email (dev → mailhog)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pm-platform.local

# Zalo OA bot (production only, leave empty in dev)
ZALO_OA_TOKEN=
ZALO_OA_SECRET=

# AI providers
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=          # For embeddings if used
AI_DEFAULT_PROVIDER=deepseek
AI_REASONING_PROVIDER=claude

# Observability (OTLP endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=         # Override per service in its env
